  year={2012},
  author={Emre Keskin and Emre Keskin and Hasan Hüseyin Atar and Hasan Hüseyin Atar},
  doi={10.1111/j.1439-0426.2012.02031.x},
  pmid={null},
  pmcid={null},
  mag_id={2027258747},
  journal={Journal of Applied Ichthyology},
  abstract={Summary
    Sequence analysis of the cytochrome c oxidase I gene was used to confirm the identity of species in 50 commercial surimi products labeled as Alaskan pollock (Theragra chalcogramma). All sequences (655 base pairs long) produced from the samples were aligned and compared with reference sequences from the GenBank database. A Neighbor Joining tree clustered samples into eight groups. Results showed that only 16% (8/50) of the surimi samples were made from Alaskan pollock as declared. The remaining species detected in samples belonged to the families Sciaenidae (12%), Synodontidae (16%), Merlucciidae (38%), Nemipteridae (8%), Priacanthidae (2%), Mullidae (2%), and two species of Gadidae (4%).}
}

